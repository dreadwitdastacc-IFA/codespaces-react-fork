# Environment variables for the React application
# Copy this file to .env.local to customize API endpoints

# CoinGecko API URL (for Litecoin price data)
# If your network blocks the default API, you can use a proxy or alternative endpoint
# VITE_COINGECKO_API_URL=https://api.coingecko.com/api/v3/simple/price?ids=litecoin&vs_currencies=usd

# Mempool.space API URL (for Litecoin mempool transactions)
# If your network blocks the default API, you can use a proxy or alternative endpoint
# VITE_MEMPOOL_API_URL=https://mempool.space/api/litecoin/txs/mempool

# CORS Proxy (optional)
# If you're experiencing CORS issues or firewall blocks, you can use a CORS proxy:
# Example: VITE_COINGECKO_API_URL=https://cors-anywhere.herokuapp.com/https://api.coingecko.com/api/v3/simple/price?ids=litecoin&vs_currencies=usd
# Example: VITE_MEMPOOL_API_URL=https://cors-anywhere.herokuapp.com/https://mempool.space/api/litecoin/txs/mempool

# Note: Using public CORS proxies in production is not recommended for security and reliability reasons.
# Consider setting up your own proxy server or backend API if you need to work around firewall restrictions.
